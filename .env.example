# ==========================================
# AetherCrawler 环境配置文件
# ==========================================

# PostgreSQL 数据库连接URL (必须使用异步 asyncpg 驱动)
# 格式: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/aethercrawler

# Redis / Celery 分布式任务队列后端配置
REDIS_URL=redis://localhost:6379/0

# OpenAI API Key (用于加密货币新闻/社交情绪分析)
OPENAI_API_KEY=sk-your-openai-api-key-here

# CoinGecko API 基础地址 (如果有 Pro 版本，可以替换 URL)
COINGECKO_API_BASE=https://api.coingecko.com/api/v3

# 爬虫设置 (生产环境建议为 True，开发调试时可改为 False)
PLAYWRIGHT_HEADLESS=True

# 统一 HTTP 请求超时设置
HTTP_TIMEOUT=30
